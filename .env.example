# --- Garas (HKR) környezeti változók ---

# MongoDB (a docker-compose alapból ezt használja, konténeren belül a host: mongo)
MONGO_URI=mongodb://mongo:27017/garas

# Backend
PORT=4000
# Vesszővel elválasztott engedélyezett originök (CORS)
CORS_ORIGINS=http://localhost:5173

# Clerk kulcsok — https://dashboard.clerk.com
# Ha a CLERK_SECRET_KEY nincs megadva ÉS NODE_ENV != production,
# a backend fejlesztői auth módban fut (x-dev-user header azonosít).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Frontend (Vite — a frontend/.env-be is kerülhet)
VITE_API_URL=http://localhost:4000
VITE_CLERK_PUBLISHABLE_KEY=
